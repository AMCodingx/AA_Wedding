---
import BaseLayout from './BaseLayout.astro';
import Header from '~/components/layout/Header.astro';
import Footer from '~/components/layout/Footer.astro';
import { useTranslations, type Locale } from '~/i18n';
import { type RouteKey } from '~/lib/url';

interface Props {
  locale: Locale;
  title: string;
  description: string;
  routeKey?: RouteKey;
  preloadImage?: string;
  ogImage?: string;
}

const { locale, title, description, routeKey, preloadImage, ogImage } = Astro.props;
const t = useTranslations(locale);
---

<BaseLayout
  locale={locale}
  title={title}
  description={description}
  routeKey={routeKey}
  preloadImage={preloadImage}
  ogImage={ogImage}
>
  <a href="#main" class="skip-link">{t('nav.skip')}</a>
  <Header locale={locale} current={routeKey} />
  <main id="main">
    <slot />
  </main>
  <Footer locale={locale} />
</BaseLayout>

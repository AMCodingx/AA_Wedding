---
import '~/styles/global.css';
import { type Locale } from '~/i18n';
import { LOCALE_BCP47 } from '~/i18n/locales';
import { buildSeo, SITE_NAME } from '~/lib/seo';
import { type RouteKey } from '~/lib/url';

interface Props {
  locale: Locale;
  title: string;
  description: string;
  routeKey?: RouteKey;
  /** Path under /public — preloaded for the LCP image. */
  preloadImage?: string;
  ogImage?: string;
}

const { locale, title, description, routeKey, preloadImage, ogImage } = Astro.props;

const seo = buildSeo({
  site: Astro.site ?? new URL('http://localhost:4321'),
  pathname: Astro.url.pathname,
  locale,
  routeKey,
  title,
  description,
  ogImage,
});

const fullTitle = title === SITE_NAME ? title : `${title} · ${SITE_NAME}`;
---

<!doctype html>
<html lang={LOCALE_BCP47[locale]} dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#79C2B9" />
    <meta name="color-scheme" content="light" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={seo.canonical.toString()} />

    {
      seo.hreflang.map(({ locale: l, href }) => (
        <link rel="alternate" hreflang={l} href={href} />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={seo.hreflang[0].href} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={seo.canonical.toString()} />
    <meta property="og:locale" content={LOCALE_BCP47[locale]} />
    {seo.ogImage && <meta property="og:image" content={seo.ogImage.toString()} />}

    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    {/*
      Preload the two fonts that actually power the design — display
      script for headings and the variable Poppins for body. These match
      the @font-face rules in styles/typography.css. (The previous
      preloads pointed to fraunces-variable.woff2 and inter-variable.woff2
      which weren't installed, costing two 404s on the critical path.)
    */}
    <link
      rel="preload"
      href="/fonts/reklame-script-regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/poppins-variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    {
      preloadImage && (
        <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />
      )
    }

    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  body {
    display: flex;
    flex-direction: column;
    min-height: 100dvh;
    background: var(--bg);
    color: var(--text);
  }
</style>

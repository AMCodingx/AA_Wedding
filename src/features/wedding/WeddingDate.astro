---
import Icon, { type IconName } from '~/components/ui/Icon.astro';
import { useTranslations, type Locale } from '~/i18n';
import { formatTime, getDateParts } from '~/lib/date';
import { WEDDING } from '~/lib/wedding';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const dp = getDateParts(WEDDING.ceremonyAt, locale);

const steps: { icon: IconName; label: string; time: string }[] = [
  {
    icon: 'sun',
    label: t('wedding.date.ceremony'),
    time: formatTime(WEDDING.ceremonyAt, locale),
  },
  {
    icon: 'fork',
    label: t('wedding.date.cocktail'),
    time: formatTime(WEDDING.cocktailAt, locale),
  },
  {
    icon: 'heart',
    label: t('wedding.date.reception'),
    time: formatTime(WEDDING.receptionAt, locale),
  },
];
---

<article class="wedding-date stack">
  <header class="wedding-date__header">
    <Icon name="calendar" size={28} />
    <h1>{t('wedding.date.title')}</h1>
  </header>

  <p class="save-date" aria-label={`${dp.weekday}, ${dp.day} ${dp.month} ${dp.year}`}>
    <span class="save-date__weekday">{dp.weekday}</span>
    <span class="save-date__numerals" aria-hidden="true">
      <span class="save-date__side">
        <span class="save-date__month">{dp.month}</span>
      </span>
      <span class="save-date__day">{dp.day}</span>
      <span class="save-date__side save-date__side--right">
        <span class="save-date__year">{dp.year}</span>
      </span>
    </span>
  </p>

  <ol class="timeline">
    {
      steps.map((step, i) => (
        <li class="timeline__item" style={`--i:${i}`}>
          <span class="timeline__pill" aria-hidden="true">
            {String(i + 1).padStart(2, '0')}
          </span>
          <span class="timeline__icon" aria-hidden="true">
            <Icon name={step.icon} size={20} />
          </span>
          <span class="timeline__label">{step.label}</span>
          <span class="timeline__time">{step.time}</span>
        </li>
      ))
    }
  </ol>
</article>

<style>
  .wedding-date__header {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--accent);
  }
  .wedding-date__header h1 {
    font-size: var(--fs-xl);
    color: var(--text);
  }

  .save-date {
    margin: 0;
    display: grid;
    justify-items: center;
    gap: var(--space-3);
    padding-block: var(--space-2);
    text-align: center;
  }
  .save-date__weekday {
    font-family: var(--font-subtitle);
    font-weight: var(--weight-subtitle);
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.32em;
    font-size: var(--fs-xs);
    /* Optical correction: tracked text drifts left of centre. */
    padding-inline-start: 0.32em;
  }
  .save-date__numerals {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    column-gap: var(--space-4);
    inline-size: 100%;
    max-inline-size: 24rem;
  }
  .save-date__side {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--text-muted);
    font-family: var(--font-subtitle);
    font-weight: var(--weight-subtitle);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    white-space: nowrap;
    min-inline-size: 0;
  }
  .save-date__side::after {
    content: '';
    flex: 1;
    block-size: 1px;
    background: var(--c-sand);
  }
  .save-date__side--right {
    justify-content: flex-end;
  }
  .save-date__side--right::after {
    content: none;
  }
  .save-date__side--right::before {
    content: '';
    flex: 1;
    block-size: 1px;
    background: var(--c-sand);
  }
  .save-date__day {
    font-family: var(--font-display);
    font-size: clamp(4rem, 3rem + 6vw, 6.5rem);
    line-height: 0.9;
    color: var(--text);
  }
  .save-date__month,
  .save-date__year {
    color: var(--text-muted);
  }

  @media (max-width: 419px) {
    .save-date__numerals {
      grid-template-columns: 1fr;
      row-gap: var(--space-2);
      justify-items: center;
    }
    .save-date__side,
    .save-date__side--right {
      justify-content: center;
    }
    .save-date__side::after,
    .save-date__side--right::before {
      content: none;
    }
    .save-date__side--right {
      order: 3;
    }
    .save-date__day {
      order: 2;
    }
  }

  .timeline {
    position: relative;
    list-style: none;
    margin: 0;
    padding: 0;
    padding-inline-start: var(--space-12);
    display: grid;
    gap: var(--space-6);
  }
  .timeline::before {
    content: '';
    position: absolute;
    inset-block: var(--space-3);
    inset-inline-start: calc(var(--space-6) - 0.5px);
    width: 1px;
    background: var(--accent-soft);
  }

  .timeline__item {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    column-gap: var(--space-4);
    padding: var(--space-3) var(--space-4);
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    opacity: 0;
    transform: translateY(8px);
    animation: timeline-in var(--dur-slow) var(--ease-out) forwards;
    animation-delay: calc(var(--i, 0) * 120ms);
  }

  .timeline__pill {
    position: absolute;
    inset-inline-start: calc(-1 * var(--space-12));
    inline-size: calc(var(--space-8) + var(--space-1));
    block-size: calc(var(--space-6) + var(--space-1));
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--accent);
    color: var(--text-on-accent);
    border-radius: var(--radius-pill);
    font-family: var(--font-subtitle);
    font-weight: var(--weight-subtitle);
    font-size: var(--fs-xs);
    letter-spacing: 0.08em;
    box-shadow: var(--shadow-sm);
  }

  .timeline__icon {
    color: var(--accent);
    display: inline-flex;
  }

  .timeline__label {
    font-size: var(--fs-sm);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .timeline__time {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    color: var(--text);
  }

  @keyframes timeline-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .timeline__item {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }

  @media (min-width: 720px) {
    .timeline {
      padding-inline: var(--space-12) var(--space-6);
    }
  }
</style>

---
import ImageCard from '~/components/ui/ImageCard.astro';
import Badge from '~/components/ui/Badge.astro';
import Icon, { type IconName } from '~/components/ui/Icon.astro';
import { TIPS, type TipCategory } from './tips.data';
import { useTranslations, type Locale } from '~/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

type CategoryMeta = { id: TipCategory; icon: IconName; tone: 'sea' | 'sand' | 'mist' | 'outline' };

const categories: CategoryMeta[] = [
  { id: 'food',       icon: 'fork',   tone: 'sand' },
  { id: 'activities', icon: 'sun',    tone: 'sea'  },
  { id: 'sights',     icon: 'camera', tone: 'mist' },
  { id: 'beach',      icon: 'wave',   tone: 'outline' },
];
---

<div class="tips">
  <fieldset class="tips__filters" aria-label={t('tips.filter.label')}>
    <legend class="visually-hidden">{t('tips.filter.label')}</legend>

    <input class="tips__radio" type="radio" id="tips-all" name="tips-filter" value="all" checked />
    <label class="tips__pill" for="tips-all">{t('tips.filter.all')}</label>

    {categories.map((cat) => (
      <>
        <input class="tips__radio" type="radio" id={`tips-${cat.id}`} name="tips-filter" value={cat.id} />
        <label class="tips__pill" for={`tips-${cat.id}`}>
          <Icon name={cat.icon} size={16} />
          <span>{t(`tips.filter.${cat.id}`)}</span>
        </label>
      </>
    ))}
  </fieldset>

  {categories.map((cat) => {
    const tips = TIPS.filter((tip) => tip.category === cat.id);
    const catLabel = t(`tips.filter.${cat.id}`);
    return (
      <div class="tips__section" data-section={cat.id}>
        <ul class="tips__grid">
          {tips.map((tip) => (
            <li id={tip.id}>
              <ImageCard image={tip.image} alt={tip.name} title={tip.name}>
                <Badge slot="badge" tone={cat.tone}>
                  <Icon name={cat.icon} size={12} />
                  {catLabel}
                </Badge>
                <p>{tip.blurb[locale]}</p>
              </ImageCard>
            </li>
          ))}
        </ul>
      </div>
    );
  })}
</div>

<style>
  .tips__filters {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2);
    border: 0;
    margin: 0 0 var(--space-8);
    padding: 0;
  }

  .tips__radio {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
  }

  .tips__pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    white-space: nowrap;
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-pill);
    border: 1px solid transparent;
    background: var(--surface);
    cursor: pointer;
    font-size: var(--fs-sm);
    font-weight: 600;
    color: var(--text);
    transition:
      background var(--dur-fast) var(--ease-out),
      color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out),
      box-shadow var(--dur-fast) var(--ease-out),
      transform var(--dur-fast) var(--ease-out);
  }

  .tips__pill:hover {
    border-color: var(--border-strong);
  }

  .tips__radio:focus-visible + .tips__pill {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .tips__radio:checked + .tips__pill {
    background: var(--accent);
    color: var(--text-on-accent);
    border-color: var(--accent);
    box-shadow: var(--shadow-md);
    transform: translateY(-1px);
  }

  @media (max-width: 599px) {
    .tips__pill {
      flex: 1 1 calc(50% - var(--space-2));
      padding-inline: var(--space-3);
    }

    .tips__pill[for='tips-all'] {
      flex-basis: 100%;
    }
  }

  /* Show / hide sections based on selected filter */
  .tips__section {
    display: none;
  }

  .tips:has(#tips-all:checked) .tips__section,
  .tips:has(#tips-food:checked) .tips__section[data-section='food'],
  .tips:has(#tips-activities:checked) .tips__section[data-section='activities'],
  .tips:has(#tips-sights:checked) .tips__section[data-section='sights'],
  .tips:has(#tips-beach:checked) .tips__section[data-section='beach'] {
    display: block;
  }

  /* When showing all, add spacing between category sections */
  .tips:has(#tips-all:checked) .tips__section + .tips__section {
    margin-block-start: var(--space-12);
  }

  /* Tip cards grid */
  .tips__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 1fr;
  }

  @media (min-width: 600px) {
    .tips__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 900px) {
    .tips__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>

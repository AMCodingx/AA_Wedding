---
import { Image } from 'astro:assets';
import Card from '~/components/ui/Card.astro';
import Badge from '~/components/ui/Badge.astro';
import Icon, { type IconName } from '~/components/ui/Icon.astro';
import { TIPS, type TipCategory } from './tips.data';
import { galleryByCategory } from './gallery';
import { useTranslations, type Locale } from '~/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

type CategoryMeta = { id: TipCategory; icon: IconName; tone: 'sea' | 'sand' | 'mist' | 'outline' };

const categories: CategoryMeta[] = [
  { id: 'food',       icon: 'fork',   tone: 'sand' },
  { id: 'activities', icon: 'sun',    tone: 'sea'  },
  { id: 'sights',     icon: 'camera', tone: 'mist' },
  { id: 'beach',      icon: 'wave',   tone: 'outline' },
];
---

<div class="tips">
  <fieldset class="tips__filters" aria-label={t('tips.filter.label')}>
    <legend class="visually-hidden">{t('tips.filter.label')}</legend>

    <input class="tips__radio" type="radio" id="tips-all" name="tips-filter" value="all" checked />
    <label class="tips__pill" for="tips-all">{t('tips.filter.all')}</label>

    {categories.map((cat) => (
      <>
        <input class="tips__radio" type="radio" id={`tips-${cat.id}`} name="tips-filter" value={cat.id} />
        <label class="tips__pill" for={`tips-${cat.id}`}>
          <Icon name={cat.icon} size={16} />
          <span>{t(`tips.filter.${cat.id}`)}</span>
        </label>
      </>
    ))}
  </fieldset>

  {categories.map((cat) => {
    const imgs = galleryByCategory[cat.id];
    const tips = TIPS.filter((tip) => tip.category === cat.id);
    const catLabel = t(`tips.filter.${cat.id}`);
    return (
      <div class="tips__section" data-section={cat.id}>
        {imgs.length > 0 && (
          <div class="tips__gallery" aria-label={t('tips.gallery.alt').replace('{category}', catLabel)}>
            {imgs.map((img) => (
              <div class="tips__gallery-item">
                <Image
                  src={img}
                  alt={t('tips.gallery.alt').replace('{category}', catLabel)}
                  widths={[400, 800]}
                  sizes="(min-width: 768px) 25vw, 45vw"
                  format="avif"
                  quality={78}
                  loading="lazy"
                  decoding="async"
                  class="tips__gallery-img"
                />
              </div>
            ))}
          </div>
        )}

        <ul class="tips__grid">
          {tips.map((tip) => (
            <li id={tip.id}>
              <Card elevation="sm" as="article">
                <div class="tips__card-header">
                  <h3>{tip.name}</h3>
                  <Badge tone={cat.tone}>
                    <Icon name={cat.icon} size={12} />
                    {catLabel}
                  </Badge>
                </div>
                <p>{tip.blurb[locale]}</p>
              </Card>
            </li>
          ))}
        </ul>
      </div>
    );
  })}
</div>

<style>
  .tips__filters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    border: 0;
    margin: 0 0 var(--space-8);
    padding: var(--space-1);
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
  }

  .tips__radio {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
  }

  .tips__pill {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-pill);
    cursor: pointer;
    font-size: var(--fs-sm);
    font-weight: 600;
    color: var(--text-muted);
    transition:
      background var(--dur-fast) var(--ease-out),
      color var(--dur-fast) var(--ease-out);
  }

  .tips__pill:hover {
    color: var(--text);
  }

  .tips__radio:focus-visible + .tips__pill {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .tips__radio:checked + .tips__pill {
    background: var(--accent);
    color: var(--text-on-accent);
  }

  /* Show / hide sections based on selected filter */
  .tips__section {
    display: none;
  }

  .tips:has(#tips-all:checked) .tips__section,
  .tips:has(#tips-food:checked) .tips__section[data-section='food'],
  .tips:has(#tips-activities:checked) .tips__section[data-section='activities'],
  .tips:has(#tips-sights:checked) .tips__section[data-section='sights'],
  .tips:has(#tips-beach:checked) .tips__section[data-section='beach'] {
    display: block;
  }

  /* When showing all, add spacing between category sections */
  .tips:has(#tips-all:checked) .tips__section + .tips__section {
    margin-block-start: var(--space-12);
  }

  /* Gallery strip */
  .tips__gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(180px, 45vw), 1fr));
    gap: var(--space-2);
    margin-block-end: var(--space-8);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .tips__gallery-item {
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .tips__gallery-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--dur-base) var(--ease-out);
  }

  .tips__gallery-item:hover .tips__gallery-img {
    transform: scale(1.04);
  }

  @media (prefers-reduced-motion: reduce) {
    .tips__gallery-img {
      transition: none;
    }
  }

  /* Tip cards grid */
  .tips__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 1fr;
  }

  @media (min-width: 600px) {
    .tips__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 900px) {
    .tips__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .tips__card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-3);
    margin-block-end: var(--space-2);
  }

  .tips__card-header h3 {
    font-size: var(--fs-base);
    margin: 0;
    line-height: 1.2;
  }

  .tips__grid p {
    color: var(--text-muted);
    font-size: var(--fs-sm);
    margin: 0;
    line-height: 1.6;
  }
</style>

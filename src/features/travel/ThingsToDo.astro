---
/**
 * "Things to do" tabs — Activities / Culture / Food / Beaches.
 * Implemented with native radio inputs + :checked state, so it works
 * with zero JS and is fully keyboard accessible (arrow keys via the
 * radio group).
 */
import Card from '~/components/ui/Card.astro';
import Icon, { type IconName } from '~/components/ui/Icon.astro';
import { HIGHLIGHTS, type ThingsToDoTab } from './places.data';
import { useTranslations, type Locale } from '~/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const tabs: Array<{ id: ThingsToDoTab; label: string; icon: IconName }> = [
  { id: 'activities', label: t('travel.tabs.activities'), icon: 'sun' },
  { id: 'culture', label: t('travel.tabs.culture'), icon: 'heart' },
  { id: 'food', label: t('travel.tabs.food'), icon: 'fork' },
  { id: 'beaches', label: t('travel.tabs.beaches'), icon: 'wave' },
];
---

<div class="things">
  <fieldset class="things__tabs" role="tablist" aria-label={t('travel.things.title')}>
    <legend class="visually-hidden">{t('travel.things.title')}</legend>
    {
      tabs.map((tab, i) => (
        <>
          <input
            class="things__radio"
            type="radio"
            id={`tab-${tab.id}`}
            name="things-tab"
            value={tab.id}
            checked={i === 0}
          />
          <label class="things__tab" for={`tab-${tab.id}`}>
            <Icon name={tab.icon} size={18} />
            <span>{tab.label}</span>
          </label>
        </>
      ))
    }
  </fieldset>

  {
    tabs.map((tab) => {
      const items = HIGHLIGHTS.filter((h) => h.tab === tab.id);
      return (
        <div class="things__panel" data-panel={tab.id} role="tabpanel" aria-labelledby={`tab-${tab.id}`}>
          <ul class="things__grid">
            {items.map((item) => (
              <li>
                <Card elevation="sm" class="things__card">
                  <h3>{item.title[locale]}</h3>
                  <p>{item.description[locale]}</p>
                </Card>
              </li>
            ))}
          </ul>
        </div>
      );
    })
  }
</div>

<style>
  .things__tabs {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    border: 0;
    padding: 0;
    margin: 0 0 var(--space-8);
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
    padding: var(--space-1);
  }

  .things__radio {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
  }

  .things__tab {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-pill);
    cursor: pointer;
    font-size: var(--fs-sm);
    font-weight: 600;
    color: var(--text-muted);
    transition:
      background var(--dur-fast) var(--ease-out),
      color var(--dur-fast) var(--ease-out);
  }

  .things__tab:hover {
    color: var(--text);
  }

  .things__radio:focus-visible + .things__tab {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .things__radio:checked + .things__tab {
    background: var(--accent);
    color: var(--text-on-accent);
  }

  /* Panels — show the panel whose id matches the selected radio. */
  .things__panel {
    display: none;
  }
  .things:has(#tab-activities:checked) .things__panel[data-panel='activities'],
  .things:has(#tab-culture:checked) .things__panel[data-panel='culture'],
  .things:has(#tab-food:checked) .things__panel[data-panel='food'],
  .things:has(#tab-beaches:checked) .things__panel[data-panel='beaches'] {
    display: block;
  }

  .things__grid {
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 1fr;
  }
  @media (min-width: 720px) {
    .things__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .things__card h3 {
    font-size: var(--fs-lg);
    margin: 0 0 var(--space-2);
  }

  .things__card p {
    color: var(--text-muted);
    margin: 0;
  }
</style>

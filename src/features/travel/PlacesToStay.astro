---
import Card from '~/components/ui/Card.astro';
import Badge from '~/components/ui/Badge.astro';
import Button from '~/components/ui/Button.astro';
import Icon from '~/components/ui/Icon.astro';
import { PLACES, type Place } from './places.data';
import { type Locale } from '~/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const kindLabel: Record<Place['kind'], Record<Locale, string>> = {
  hotel: { nl: 'Hotel', es: 'Hotel', en: 'Hotel' },
  apartment: { nl: 'Appartement', es: 'Apartamento', en: 'Apartment' },
  guesthouse: { nl: 'Vakantiehuis', es: 'Casa rural', en: 'Guesthouse' },
};

const walkingLabel: Record<Locale, (m: number) => string> = {
  nl: (m) => `${m} min lopen`,
  es: (m) => `${m} min a pie`,
  en: (m) => `${m} min on foot`,
};

const fromLabel: Record<Locale, string> = {
  nl: 'vanaf',
  es: 'desde',
  en: 'from',
};

const visitLabel: Record<Locale, string> = {
  nl: 'Reserveren',
  es: 'Reservar',
  en: 'Book',
};
---

<ul class="places__grid">
  {
    PLACES.map((place) => (
      <li>
        <Card elevation="sm" class="place">
          <Badge tone="mist">{kindLabel[place.kind][locale]}</Badge>
          <h3 class="place__name">{place.name}</h3>
          <p class="place__blurb">{place.blurb[locale]}</p>
          <dl class="place__meta">
            <div>
              <dt class="visually-hidden">Walking</dt>
              <dd>
                <Icon name="pin" size={14} />
                <span>{walkingLabel[locale](place.walkingMinutes)}</span>
              </dd>
            </div>
            <div>
              <dt class="visually-hidden">Price</dt>
              <dd>
                <strong>{fromLabel[locale]} €{place.priceFromEUR}</strong>
              </dd>
            </div>
          </dl>
          <Button variant="outline" size="sm" href={place.url}>
            <span>{visitLabel[locale]}</span>
            <Icon name="external" size={14} />
          </Button>
        </Card>
      </li>
    ))
  }
</ul>

<style>
  .places__grid {
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 1fr;
  }
  @media (min-width: 720px) {
    .places__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .places__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .place {
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .place__name {
    font-size: var(--fs-lg);
    margin: 0;
  }

  .place__blurb {
    color: var(--text-muted);
    font-size: var(--fs-sm);
    flex: 1 0 auto;
  }

  .place__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    font-size: var(--fs-sm);
    color: var(--text-muted);
    margin: 0;
  }
  .place__meta dd {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    margin: 0;
  }
  .place__meta strong {
    color: var(--text);
  }
</style>

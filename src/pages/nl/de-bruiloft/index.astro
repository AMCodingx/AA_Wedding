---
import PageLayout from '~/layouts/PageLayout.astro';
import Section from '~/components/ui/Section.astro';
import Button from '~/components/ui/Button.astro';
import WeddingDate from '~/features/wedding/WeddingDate.astro';
import WeddingLocation from '~/features/wedding/WeddingLocation.astro';
import { useTranslations } from '~/i18n';
import { href } from '~/lib/url';

const locale = 'nl' as const;
const t = useTranslations(locale);
---

<PageLayout
  locale={locale}
  routeKey="wedding"
  title={t('wedding.title')}
  description={t('wedding.intro')}
>
  <Section tone="shell" spacing="lg" width="narrow">
    <header class="page-header stack-sm">
      <h1>{t('wedding.title')}</h1>
      <p>{t('wedding.intro')}</p>
    </header>
  </Section>

  <Section tone="elevated" spacing="md" width="narrow">
    <WeddingDate locale={locale} />
  </Section>

  <Section tone="shell" spacing="md" width="narrow">
    <WeddingLocation locale={locale} />
  </Section>

  <Section tone="mist" spacing="md" width="narrow">
    <div class="cta">
      <h2>{t('wedding.faq.title')}</h2>
      <p>{t('wedding.faq.intro')}</p>
      <Button variant="primary" href={href(locale, 'weddingFaq')}>
        {t('wedding.faq.title')}
      </Button>
    </div>
  </Section>
</PageLayout>

<style>
  .page-header {
    text-align: center;
  }
  .page-header p {
    color: var(--text-muted);
  }
  .cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    text-align: center;
  }
  .cta p {
    color: var(--text-muted);
  }
</style>

---
import PageLayout from '~/layouts/PageLayout.astro';
import Section from '~/components/ui/Section.astro';
import FAQ from '~/features/wedding/FAQ.astro';
import { useTranslations } from '~/i18n';

const locale = 'nl' as const;
const t = useTranslations(locale);
---

<PageLayout
  locale={locale}
  routeKey="weddingFaq"
  title={t('wedding.faq.title')}
  description={t('wedding.faq.intro')}
>
  <Section tone="shell" spacing="lg" width="narrow">
    <FAQ locale={locale} />
  </Section>
</PageLayout>

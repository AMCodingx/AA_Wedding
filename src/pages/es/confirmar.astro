---
import PageLayout from '~/layouts/PageLayout.astro';
import Section from '~/components/ui/Section.astro';
import RsvpInstructions from '~/features/rsvp/RsvpInstructions.astro';
import { useTranslations } from '~/i18n';

const locale = 'es' as const;
const t = useTranslations(locale);
---

<PageLayout
  locale={locale}
  routeKey="rsvp"
  title={t('rsvp.title')}
  description={t('rsvp.intro')}
>
  <Section tone="elevated" spacing="md" width="narrow">
    <RsvpInstructions locale={locale} />
  </Section>
</PageLayout>

---
import PageLayout from '~/layouts/PageLayout.astro';
import Section from '~/components/ui/Section.astro';
import WeddingDate from '~/features/wedding/WeddingDate.astro';
import WeddingLocation from '~/features/wedding/WeddingLocation.astro';
import { useTranslations } from '~/i18n';

const locale = 'es' as const;
const t = useTranslations(locale);
---

<PageLayout
  locale={locale}
  routeKey="wedding"
  title={t('wedding.title')}
  description={t('wedding.intro')}
>
  <Section tone="elevated" spacing="lg" width="narrow" class="beach-pattern">
    <WeddingDate locale={locale} />
    <hr class="section-divider" aria-hidden="true" />
    <WeddingLocation locale={locale} />
  </Section>

</PageLayout>

---
import PageLayout from '~/layouts/PageLayout.astro';
import Section from '~/components/ui/Section.astro';
import PlacesToStay from '~/features/travel/PlacesToStay.astro';
import { useTranslations } from '~/i18n';

const locale = 'es' as const;
const t = useTranslations(locale);
---

<PageLayout
  locale={locale}
  routeKey="travelPlaces"
  title={t('travel.places.title')}
  description={t('travel.intro')}
>
  <Section tone="shell" spacing="lg" width="narrow">
    <header class="page-header stack-sm">
      <h1>{t('travel.places.title')}</h1>
      <p>{t('travel.intro')}</p>
    </header>
  </Section>

  <Section tone="elevated" spacing="lg">
    <PlacesToStay locale={locale} />
  </Section>
</PageLayout>

<style>
  .page-header {
    text-align: center;
  }
  .page-header p {
    color: var(--text-muted);
  }
</style>

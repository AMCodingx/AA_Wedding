---
import Nav from './Nav.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { useTranslations, type Locale } from '~/i18n';
import { href, type RouteKey } from '~/lib/url';
import { WEDDING } from '~/lib/wedding';

interface Props {
  locale: Locale;
  current?: RouteKey;
}

const { locale, current } = Astro.props;
const t = useTranslations(locale);
---

<header class="header">
  <div class="container header__inner">
    <a class="header__brand" href={href(locale, 'home')} aria-label={t('site.title')}>
      <span class="header__monogram" aria-hidden="true">
        {WEDDING.couple.partnerOne[0]}<span>&amp;</span>{WEDDING.couple.partnerTwo[0]}
      </span>
      <span class="header__title">{t('site.title')}</span>
    </a>
    <div class="header__right">
      <Nav locale={locale} current={current} />
      <LanguageSwitcher current={locale} routeKey={current} />
    </div>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: var(--z-header);
    background: color-mix(in srgb, var(--bg) 90%, transparent);
    backdrop-filter: saturate(140%) blur(8px);
    -webkit-backdrop-filter: saturate(140%) blur(8px);
    border-bottom: 1px solid var(--border);
  }

  .header__inner {
    height: var(--header-h);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .header__brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    color: var(--text);
  }

  .header__monogram {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: 500;
    line-height: 1;
    color: var(--accent);
    letter-spacing: 0.02em;
  }
  .header__monogram span {
    color: var(--text-muted);
    font-style: italic;
    margin-inline: 0.05em;
  }

  .header__title {
    font-family: var(--font-display);
    font-size: var(--fs-base);
    font-weight: 500;
  }

  .header__right {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  @media (max-width: 540px) {
    .header__title {
      display: none;
    }
    .header__right {
      gap: var(--space-2);
    }
  }
</style>

---
import { useTranslations, type Locale } from '~/i18n';
import { href, type RouteKey } from '~/lib/url';

interface Props {
  locale: Locale;
  current?: RouteKey;
}

const { locale, current } = Astro.props;
const t = useTranslations(locale);

interface Item {
  key: RouteKey;
  label: string;
}

const items: Item[] = [
  { key: 'home', label: t('nav.home') },
  { key: 'wedding', label: t('nav.wedding') },
  { key: 'tips', label: t('nav.tips') },
  { key: 'rsvp', label: t('nav.rsvp') },
  { key: 'faq', label: t('nav.faq') },
];

const numerals = ['i', 'ii', 'iii', 'iv', 'v'] as const;
---

<nav class="nav" aria-label={t('nav.menu')}>
  <ul class="nav__list">
    {
      items.map((item) => (
        <li>
          <a
            class="nav__link"
            href={href(locale, item.key)}
            aria-current={item.key === current ? 'page' : undefined}
          >
            {item.label}
          </a>
        </li>
      ))
    }
  </ul>

  <details class="nav__drawer" data-nav-drawer>
    <summary class="nav__toggle" aria-label={t('nav.menu')}>
      <span class="nav__bars" aria-hidden="true">
        <span></span>
        <span></span>
      </span>
    </summary>

    <div class="nav__backdrop" data-nav-backdrop aria-hidden="true"></div>

    <div class="nav__sheet" role="dialog" aria-modal="true" aria-label={t('nav.menu')}>
      <ul class="nav__sheet-list">
        {
          items.map((item, i) => (
            <li class="nav__sheet-item" style={`--i:${i}`}>
              <a
                class="nav__sheet-link"
                href={href(locale, item.key)}
                aria-current={item.key === current ? 'page' : undefined}
              >
                <span class="nav__sheet-num" aria-hidden="true">{numerals[i]}</span>
                <span class="nav__sheet-label">{item.label}</span>
                <svg
                  class="nav__sheet-arrow"
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    d="M5 12h14 M13 6l6 6-6 6"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </details>
</nav>

{/*
  Progressive enhancement: smooth close, focus management, body lock,
  Escape-to-close, backdrop tap. Without this script the <details>
  still works — open/close just snaps instead of animating out.
  Inline so it executes before paint and doesn't block.
*/}
<script is:inline>
  (() => {
    const drawer = document.querySelector('[data-nav-drawer]');
    if (!drawer) return;

    const summary = drawer.querySelector('summary');
    const backdrop = drawer.querySelector('[data-nav-backdrop]');
    const sheet = drawer.querySelector('.nav__sheet');
    const firstLink = drawer.querySelector('.nav__sheet-link');
    const root = document.documentElement;

    let lastFocus = null;

    const close = () => {
      if (!drawer.open || drawer.dataset.closing) return;
      drawer.dataset.closing = '';
      const done = () => {
        delete drawer.dataset.closing;
        drawer.open = false;
        root.classList.remove('is-nav-open');
        if (lastFocus && lastFocus.focus) lastFocus.focus();
      };
      // Wait for the sheet's exit animation; fall back to a timeout so we
      // can never strand the drawer in a half-closed state.
      let settled = false;
      const onEnd = () => {
        if (settled) return;
        settled = true;
        sheet.removeEventListener('animationend', onEnd);
        done();
      };
      sheet.addEventListener('animationend', onEnd);
      setTimeout(onEnd, 320);
    };

    const open = () => {
      lastFocus = document.activeElement;
      root.classList.add('is-nav-open');
      // Defer focus to next frame so the sheet has rendered.
      requestAnimationFrame(() => firstLink && firstLink.focus({ preventScroll: true }));
    };

    summary.addEventListener('click', (e) => {
      if (drawer.open) {
        e.preventDefault();
        close();
      }
    });

    // <details> only fires `toggle` after open changes — use it to run
    // open-side side-effects without racing the click handler.
    drawer.addEventListener('toggle', () => {
      if (drawer.open) open();
    });

    backdrop.addEventListener('click', close);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && drawer.open) {
        e.preventDefault();
        close();
      }
    });

    // Resize past the desktop breakpoint while the menu is open: the
    // drawer becomes display:none, so reset state instantly to avoid
    // stranding the body scroll-lock or focus.
    const mq = window.matchMedia('(min-width: 720px)');
    const onMq = (e) => {
      if (e.matches && drawer.open) {
        delete drawer.dataset.closing;
        drawer.open = false;
        root.classList.remove('is-nav-open');
      }
    };
    mq.addEventListener('change', onMq);
  })();
</script>

<style>
  .nav {
    display: contents;
  }

  /* —————————————————— Desktop list —————————————————— */
  .nav__list {
    display: none;
    align-items: center;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav__link {
    display: inline-block;
    padding: var(--space-2) var(--space-3);
    text-decoration: none;
    color: var(--text);
    font-weight: 500;
    font-size: var(--fs-sm);
    white-space: nowrap;
    /* No hover or click affordance — the underline carries the state. */
  }

  .nav__link[aria-current='page'] {
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-decoration-thickness: 2px;
    text-underline-offset: 6px;
  }

  /* Keep keyboard users oriented — focus ring is preserved. */
  .nav__link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
    border-radius: var(--radius-sm);
  }

  /* —————————————————— Toggle —————————————————— */
  .nav__drawer {
    position: relative;
  }

  /* Lift the whole drawer above the header while it's animating, so the
     sheet's gradient can flow continuously under the (transparent) header
     and the toggle stays the topmost interactive surface. */
  .nav__drawer[open],
  .nav__drawer[data-closing] {
    z-index: calc(var(--z-overlay) + 1);
  }

  .nav__toggle {
    position: relative;
    /* Above the sheet within the drawer's stacking context — keeps the
       button visually anchored "on top of" the menu it produces. */
    z-index: 3;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-pill);
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    cursor: pointer;
    list-style: none;
    color: var(--text);
    transition:
      transform var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out),
      background var(--dur-base) var(--ease-out),
      box-shadow var(--dur-base) var(--ease-out),
      color var(--dur-base) var(--ease-out);
  }

  /* Tactile click feedback — quick squish on press, springs back. */
  .nav__toggle:active {
    transform: scale(0.92);
    transition-duration: 80ms;
  }
  .nav__toggle::-webkit-details-marker {
    display: none;
  }
  .nav__toggle:hover {
    border-color: var(--border-strong);
  }
  .nav__toggle:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .nav__bars {
    position: relative;
    width: 20px;
    height: 14px;
  }
  .nav__bars span {
    position: absolute;
    left: 0;
    width: 100%;
    height: 1.5px;
    background: currentColor;
    border-radius: var(--radius-pill);
    transition:
      transform var(--dur-base) var(--ease-out),
      top var(--dur-base) var(--ease-out),
      width var(--dur-base) var(--ease-out);
  }
  .nav__bars span:nth-child(1) {
    top: 4px;
  }
  .nav__bars span:nth-child(2) {
    top: 10px;
    width: 70%;
  }

  .nav__drawer[open] .nav__toggle {
    border-color: var(--accent);
    background: var(--accent-soft);
    box-shadow: 0 6px 16px -6px rgba(31, 58, 56, 0.25);
  }
  .nav__drawer[open] .nav__bars span:nth-child(1) {
    top: 7px;
    transform: rotate(45deg);
  }
  .nav__drawer[open] .nav__bars span:nth-child(2) {
    top: 7px;
    width: 100%;
    transform: rotate(-45deg);
  }
  /* Reverse the X back into bars while closing animation plays. */
  .nav__drawer[data-closing] .nav__bars span:nth-child(1) {
    top: 4px;
    transform: rotate(0);
  }
  .nav__drawer[data-closing] .nav__bars span:nth-child(2) {
    top: 10px;
    width: 70%;
    transform: rotate(0);
  }

  /* —————————————————— Backdrop —————————————————— */
  .nav__backdrop {
    position: fixed;
    inset: 0;
    z-index: 1;
    background: rgba(31, 58, 56, 0.32);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
    animation: nav-backdrop-in var(--dur-base) var(--ease-out) both;
  }
  .nav__drawer[data-closing] .nav__backdrop {
    animation: nav-backdrop-out 240ms var(--ease-out) both;
  }
  @keyframes nav-backdrop-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @keyframes nav-backdrop-out {
    from { opacity: 1; }
    to   { opacity: 0; }
  }

  /* —————————————————— Sheet —————————————————— */
  .nav__sheet {
    position: fixed;
    /* Extend to the very top so the gradient flows under the (now
       transparent) header — the menu reads as one continuous surface
       that the toggle button sits on, not a panel below it. */
    inset: 0 0 auto 0;
    z-index: 2;
    /* Pad the header zone so menu items begin below the toggle. */
    padding-block: calc(var(--header-h) + var(--space-4)) var(--space-8);
    background:
      radial-gradient(ellipse at 100% 0%, var(--c-sea-soft) 0%, transparent 60%),
      radial-gradient(ellipse at 0% 100%, var(--c-sand) 0%, transparent 55%),
      linear-gradient(180deg, var(--c-shell) 0%, var(--c-mist) 100%);
    border-bottom: 1px solid var(--border);
    box-shadow: var(--shadow-lg);
    /* Origin sits at the toggle button's center so the bloom radiates
       from the hamburger — the menu feels generated by the button. */
    --origin-x: calc(100% - var(--space-6) - 22px);
    --origin-y: calc(var(--header-h) / 2);
    will-change: clip-path, opacity;
    animation: nav-sheet-in 380ms var(--ease-out) both;
  }

  .nav__sheet::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 18px;
    background:
      url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1440 80' preserveAspectRatio='none'><path d='M0,40 C240,72 480,8 720,32 C960,56 1200,72 1440,40 L1440,80 L0,80 Z' fill='%23F6EBDF'/></svg>")
        bottom / 100% 100% no-repeat;
    pointer-events: none;
  }

  .nav__drawer[data-closing] .nav__sheet {
    animation: nav-sheet-out 280ms var(--ease-in-out) both;
  }

  /* Circular clip grows from the button → menu blooms from the toggle.
     150% radius guarantees full coverage even on tall viewports. */
  @keyframes nav-sheet-in {
    from {
      opacity: 0.6;
      clip-path: circle(0% at var(--origin-x) var(--origin-y));
    }
    to {
      opacity: 1;
      clip-path: circle(150% at var(--origin-x) var(--origin-y));
    }
  }
  @keyframes nav-sheet-out {
    from {
      opacity: 1;
      clip-path: circle(150% at var(--origin-x) var(--origin-y));
    }
    to {
      opacity: 0;
      clip-path: circle(0% at var(--origin-x) var(--origin-y));
    }
  }

  .nav__sheet-list {
    list-style: none;
    margin: 0;
    padding: 0 var(--space-6);
    max-width: 32rem;
    margin-inline: auto;
  }

  .nav__sheet-item {
    border-bottom: 1px dashed var(--border);
    opacity: 0;
    transform: translateY(10px);
    animation: nav-item-in 360ms var(--ease-out) forwards;
    /* Stagger 1→4 on open. */
    animation-delay: calc(80ms + var(--i, 0) * 55ms);
  }
  .nav__sheet-item:last-child {
    border-bottom: 0;
  }

  /* Reverse stagger on close — top item leaves first. */
  .nav__drawer[data-closing] .nav__sheet-item {
    animation: nav-item-out 200ms var(--ease-in-out) forwards;
    animation-delay: calc(var(--i, 0) * 25ms);
  }

  @keyframes nav-item-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes nav-item-out {
    from {
      opacity: 1;
      transform: translateY(0);
    }
    to {
      opacity: 0;
      transform: translateY(-6px);
    }
  }

  .nav__sheet-link {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: baseline;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-2);
    text-decoration: none;
    color: var(--text);
    transition: color var(--dur-fast) var(--ease-out);
  }
  .nav__sheet-link:hover,
  .nav__sheet-link:focus-visible {
    color: var(--accent);
  }
  .nav__sheet-link:focus-visible {
    outline: none;
    background: color-mix(in srgb, var(--accent-soft) 35%, transparent);
    border-radius: var(--radius-md);
  }

  .nav__sheet-num {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--fs-sm);
    color: var(--text-muted);
    width: 1.5rem;
    line-height: 1;
    align-self: center;
    text-align: right;
  }

  .nav__sheet-label {
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.4rem + 3.2vw, 2.75rem);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.01em;
  }

  .nav__sheet-arrow {
    color: var(--text-muted);
    align-self: center;
    transition:
      color var(--dur-fast) var(--ease-out),
      transform var(--dur-base) var(--ease-out);
  }
  .nav__sheet-link:hover .nav__sheet-arrow,
  .nav__sheet-link:focus-visible .nav__sheet-arrow {
    color: var(--accent);
    transform: translateX(4px);
  }

  .nav__sheet-link[aria-current='page'] .nav__sheet-num,
  .nav__sheet-link[aria-current='page'] .nav__sheet-label {
    color: var(--accent);
  }

  /* —————————————————— Reduced motion —————————————————— */
  @media (prefers-reduced-motion: reduce) {
    .nav__backdrop,
    .nav__sheet,
    .nav__sheet-item,
    .nav__bars span,
    .nav__sheet-arrow {
      animation: none !important;
      transition: none !important;
    }
    .nav__sheet-item {
      opacity: 1;
      transform: none;
    }
  }

  /* —————————————————— Breakpoints —————————————————— */
  @media (min-width: 720px) {
    .nav__list {
      display: flex;
    }
    .nav__drawer {
      display: none;
    }
  }
</style>

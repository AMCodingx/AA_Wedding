---
interface Props {
  size?: number;
  class?: string;
}
const { size = 18, class: className = '' } = Astro.props;
---

<svg
  class:list={['flag', className]}
  viewBox="0 0 24 16"
  width={size * 1.5}
  height={size}
  aria-hidden="true"
  focusable="false"
>
  <clipPath id="gb-clip"><rect width="24" height="16" rx="2" /></clipPath>
  <g clip-path="url(#gb-clip)">
    <rect width="24" height="16" fill="#012169"></rect>
    <path d="M0 0 L24 16 M24 0 L0 16" stroke="#FFFFFF" stroke-width="3.2"></path>
    <path d="M0 0 L24 16 M24 0 L0 16" stroke="#C8102E" stroke-width="1.6"></path>
    <path d="M12 0 V16 M0 8 H24" stroke="#FFFFFF" stroke-width="5"></path>
    <path d="M12 0 V16 M0 8 H24" stroke="#C8102E" stroke-width="2.6"></path>
  </g>
</svg>

<style>
  .flag {
    border-radius: 2px;
    box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.06);
    flex: 0 0 auto;
  }
</style>

---
interface Props {
  size?: number;
  class?: string;
}
const { size = 18, class: className = '' } = Astro.props;
---

<svg
  class:list={['flag', className]}
  viewBox="0 0 24 16"
  width={size * 1.5}
  height={size}
  aria-hidden="true"
  focusable="false"
>
  <rect width="24" height="16" rx="2" fill="#21468B"></rect>
  <rect width="24" height="11" fill="#FFFFFF"></rect>
  <rect width="24" height="5.33" fill="#AE1C28"></rect>
</svg>

<style>
  .flag {
    border-radius: 2px;
    box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.06);
    flex: 0 0 auto;
  }
</style>

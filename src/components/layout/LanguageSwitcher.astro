---
import FlagES from './flags/FlagES.astro';
import FlagNL from './flags/FlagNL.astro';
import FlagGB from './flags/FlagGB.astro';
import { LOCALES, LOCALE_LABELS, type Locale } from '~/i18n/locales';
import { useTranslations } from '~/i18n';
import { ROUTES, type RouteKey, localePath } from '~/lib/url';

interface Props {
  current: Locale;
  /** The route key for the current page; used to switch to the equivalent in the other locale. */
  routeKey?: RouteKey;
}

const { current, routeKey } = Astro.props;
const t = useTranslations(current);

function localeHref(locale: Locale): string {
  if (routeKey) return localePath(locale, ROUTES[routeKey][locale]);
  return localePath(locale);
}

const flagFor = {
  nl: FlagNL,
  es: FlagES,
  en: FlagGB,
} as const;

const CurrentFlag = flagFor[current];
---

<details class="lang">
  <summary class="lang__trigger" aria-label={t('lang.label')}>
    <CurrentFlag size={16} />
    <span class="lang__code">{current.toUpperCase()}</span>
    <svg class="lang__caret" width="10" height="10" viewBox="0 0 20 20" aria-hidden="true">
      <path
        d="M5 8l5 5 5-5"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </summary>
  <ul class="lang__menu" role="menu">
    {
      LOCALES.map((locale) => {
        const F = flagFor[locale];
        return (
          <li role="none">
            <a
              role="menuitem"
              hreflang={locale}
              href={localeHref(locale)}
              aria-current={locale === current ? 'true' : undefined}
              class="lang__item"
            >
              <F size={16} />
              <span>{LOCALE_LABELS[locale]}</span>
            </a>
          </li>
        );
      })
    }
  </ul>
</details>

<style>
  .lang {
    position: relative;
  }

  .lang__trigger {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-pill);
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    cursor: pointer;
    list-style: none;
    font-size: var(--fs-sm);
    font-weight: 600;
    color: var(--text);
    transition:
      border-color var(--dur-fast) var(--ease-out),
      background var(--dur-fast) var(--ease-out);
  }

  .lang__trigger::-webkit-details-marker {
    display: none;
  }

  .lang__trigger:hover {
    border-color: var(--border-strong);
  }

  .lang__caret {
    color: var(--text-muted);
    transition: transform var(--dur-fast) var(--ease-out);
  }

  .lang[open] .lang__caret {
    transform: rotate(180deg);
  }

  .lang__menu {
    position: absolute;
    top: calc(100% + var(--space-2));
    right: 0;
    min-width: 12rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    padding: var(--space-2);
    z-index: var(--z-overlay);
  }

  .lang__item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: var(--text);
    font-weight: 500;
    transition: background var(--dur-fast) var(--ease-out);
  }

  .lang__item:hover {
    background: var(--surface);
  }

  .lang__item[aria-current='true'] {
    color: var(--accent);
    background: var(--accent-soft);
  }
</style>

---
type Props = {
  as?: 'article' | 'section' | 'div' | 'li';
  href?: string;
  elevation?: 'flat' | 'sm' | 'md';
  class?: string;
};

const { as: Tag = 'article', href, elevation = 'sm', class: className = '' } = Astro.props as Props;
const classes = ['card', `card--${elevation}`, href && 'card--link', className]
  .filter(Boolean)
  .join(' ');
---

{
  href ? (
    <a class={classes} href={href}>
      <slot />
    </a>
  ) : (
    <Tag class={classes}>
      <slot />
    </Tag>
  )
}

<style>
  .card {
    display: block;
    background: var(--bg-elevated);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    border: 1px solid var(--border);
    color: inherit;
    text-decoration: none;
  }

  .card--flat {
    box-shadow: none;
  }
  .card--sm {
    box-shadow: var(--shadow-sm);
  }
  .card--md {
    box-shadow: var(--shadow-md);
  }

  .card--link {
    transition:
      transform var(--dur-fast) var(--ease-out),
      box-shadow var(--dur-fast) var(--ease-out);
  }

  .card--link:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }
</style>

---
/**
 * Native <details>/<summary> accordion. Keyboard + screen-reader support
 * comes for free from the platform — no JS required.
 */
interface Props {
  /** Group name — pass the same string to siblings to make only one open at a time. */
  group?: string;
  open?: boolean;
  class?: string;
}

const { group, open = false, class: className = '' } = Astro.props;
---

<details
  class:list={['accordion', className]}
  open={open}
  name={group}
>
  <summary class="accordion__summary">
    <span class="accordion__title"><slot name="title" /></span>
    <svg
      class="accordion__chevron"
      viewBox="0 0 20 20"
      width="20"
      height="20"
      aria-hidden="true"
      focusable="false"
    >
      <path
        d="M6 8l4 4 4-4"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </summary>
  <div class="accordion__body">
    <slot />
  </div>
</details>

<style>
  .accordion {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .accordion + .accordion {
    margin-top: var(--space-3);
  }

  .accordion__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-6);
    cursor: pointer;
    list-style: none;
    font-weight: 600;
    color: var(--text);
    transition: background var(--dur-fast) var(--ease-out);
  }

  .accordion__summary::-webkit-details-marker {
    display: none;
  }

  .accordion__summary:hover {
    background: var(--surface);
  }

  .accordion__title {
    font-size: var(--fs-base);
  }

  .accordion__chevron {
    flex: 0 0 auto;
    color: var(--text-muted);
    transition: transform var(--dur-base) var(--ease-out);
  }

  .accordion[open] .accordion__chevron {
    transform: rotate(180deg);
    color: var(--accent);
  }

  .accordion__body {
    padding: 0 var(--space-6) var(--space-6);
    color: var(--text-muted);
    font-size: var(--fs-base);
    line-height: 1.65;
  }

  .accordion__body :global(p + p) {
    margin-top: var(--space-3);
  }
</style>

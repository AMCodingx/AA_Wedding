---
/**
 * Native <details>/<summary> accordion. Keyboard + screen-reader support
 * comes for free from the platform — no JS required.
 */
interface Props {
  /** Group name — pass the same string to siblings to make only one open at a time. */
  group?: string;
  open?: boolean;
  class?: string;
}

const { group, open = false, class: className = '' } = Astro.props;
---

<details
  class:list={['accordion', className]}
  open={open}
  name={group}
>
  <summary class="accordion__summary">
    <span class="accordion__title"><slot name="title" /></span>
    <span class="accordion__toggle" aria-hidden="true">
      <span class="accordion__bar accordion__bar--h"></span>
      <span class="accordion__bar accordion__bar--v"></span>
    </span>
  </summary>
  <div class="accordion__body">
    <slot />
  </div>
</details>

<style>
  .accordion {
    position: relative;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition:
      border-color var(--dur-base) var(--ease-out),
      box-shadow var(--dur-base) var(--ease-out);
  }
  .accordion::before {
    content: '';
    position: absolute;
    inset-block: 0;
    inset-inline-start: 0;
    inline-size: 3px;
    background: var(--accent);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform var(--dur-base) var(--ease-out);
  }
  .accordion[open] {
    border-color: var(--accent-soft);
    box-shadow: var(--shadow-sm);
  }
  .accordion[open]::before {
    transform: scaleY(1);
  }

  .accordion + .accordion {
    margin-top: var(--space-3);
  }

  .accordion__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-6);
    cursor: pointer;
    list-style: none;
    font-weight: 500;
    color: var(--text);
    transition: background var(--dur-fast) var(--ease-out);
  }

  .accordion__summary::-webkit-details-marker {
    display: none;
  }
  .accordion__summary::marker {
    content: '';
  }

  .accordion__summary:hover {
    background: color-mix(in oklab, var(--surface) 35%, var(--bg-elevated));
  }
  .accordion__summary:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: -2px;
  }

  .accordion__title {
    font-family: var(--font-subtitle);
    font-weight: var(--weight-subtitle);
    font-size: var(--fs-base);
    line-height: 1.4;
  }

  .accordion__toggle {
    position: relative;
    flex: 0 0 auto;
    inline-size: 18px;
    block-size: 18px;
    color: var(--text-muted);
    transition: color var(--dur-base) var(--ease-out);
  }
  .accordion__bar {
    position: absolute;
    inset: 50% 0 auto 0;
    block-size: 1.5px;
    background: currentColor;
    border-radius: 2px;
    transform: translateY(-50%);
    transition: transform var(--dur-base) var(--ease-out);
  }
  .accordion__bar--v {
    transform: translateY(-50%) rotate(90deg);
  }
  .accordion[open] .accordion__toggle {
    color: var(--accent);
  }
  .accordion[open] .accordion__bar--v {
    transform: translateY(-50%) rotate(0deg);
  }

  .accordion__body {
    padding: 0 var(--space-6) var(--space-6);
    color: var(--text-muted);
    font-size: var(--fs-base);
    line-height: 1.7;
  }

  .accordion__body :global(p + p) {
    margin-top: var(--space-3);
  }
</style>

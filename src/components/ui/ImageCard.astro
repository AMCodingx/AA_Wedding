---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import Card from './Card.astro';

interface Props {
  image: ImageMetadata;
  alt: string;
  title: string;
  loading?: 'lazy' | 'eager';
  class?: string;
}

const { image, alt, title, loading = 'lazy', class: className = '' } = Astro.props;
const hasBadge = Astro.slots.has('badge');
---

<Card elevation="sm" as="article" class={`image-card ${className}`.trim()}>
  <div class="image-card__media">
    <Image
      src={image}
      alt={alt}
      widths={[400, 800]}
      sizes="(min-width: 900px) 33vw, (min-width: 600px) 50vw, 100vw"
      format="avif"
      quality={80}
      loading={loading}
      decoding="async"
      class="image-card__img"
    />
  </div>

  <div class="image-card__header">
    <h3 class="image-card__title">{title}</h3>
    {hasBadge && <slot name="badge" />}
  </div>

  <div class="image-card__body">
    <slot />
  </div>
</Card>

<style>
  .image-card {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .image-card__media {
    margin: calc(-1 * var(--space-6)) calc(-1 * var(--space-6)) var(--space-4);
    border-radius: var(--radius-lg) var(--radius-lg) var(--radius-md) var(--radius-md);
    overflow: hidden;
    aspect-ratio: 16 / 10;
  }

  .image-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--dur-base) var(--ease-out);
  }

  .image-card:hover .image-card__img {
    transform: scale(1.04);
  }

  .image-card__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-3);
    margin-block-end: var(--space-2);
  }

  .image-card__title {
    font-size: var(--fs-base);
    margin: 0;
    line-height: 1.2;
  }

  .image-card__body {
    color: var(--text-muted);
    font-size: var(--fs-sm);
    line-height: 1.6;
  }

  .image-card__body :global(p) {
    margin: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .image-card__img {
      transition: none;
    }
  }
</style>

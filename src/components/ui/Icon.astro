---
/**
 * Generic inline-SVG icon. Add new icons in the `paths` map below; the build
 * tree-shakes unused ones because they're only string literals.
 *
 * Each icon is drawn on a 24×24 viewBox using `currentColor` so it inherits
 * the surrounding text color.
 */
const paths: Record<string, string> = {
  calendar:
    'M7 4v3M17 4v3M4 9h16M5 6h14a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V7a1 1 0 0 1 1-1Z',
  pin: 'M12 21s7-6.2 7-12a7 7 0 0 0-14 0c0 5.8 7 12 7 12Z M12 11.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z',
  mail: 'M4 7h16v10H4z M4 7l8 6 8-6',
  heart:
    'M12 20s-7-4.5-7-10a4 4 0 0 1 7-2.7A4 4 0 0 1 19 10c0 5.5-7 10-7 10Z',
  arrowRight: 'M5 12h14 M13 6l6 6-6 6',
  chevronDown: 'M6 9l6 6 6-6',
  bed: 'M3 18V8m0 4h18v6 M7 13a2 2 0 1 1 0-4 2 2 0 0 1 0 4Z M11 13h10v-2a3 3 0 0 0-3-3h-7Z',
  sun: 'M12 4v2 M12 18v2 M4 12h2 M18 12h2 M5.6 5.6l1.4 1.4 M17 17l1.4 1.4 M5.6 18.4 7 17 M17 7l1.4-1.4 M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8Z',
  fork: 'M7 3v8a2 2 0 0 0 2 2v8 M11 3v8a2 2 0 0 1-2 2 M16 3c-2 0-3 2-3 5s1 5 3 5v8',
  wave:
    'M2 12c2-3 4-3 6 0s4 3 6 0 4-3 6 0 M2 17c2-3 4-3 6 0s4 3 6 0 4-3 6 0',
  external: 'M14 4h6v6 M20 4l-9 9 M19 13v6a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1h6',
};

export type IconName = keyof typeof paths;

interface Props {
  name: keyof typeof paths;
  size?: number | string;
  class?: string;
  label?: string;
}

const { name, size = 20, class: className = '', label } = Astro.props;
const d = paths[name];
if (!d) throw new Error(`Unknown icon: ${String(name)}`);
const ariaProps = label
  ? ({ role: 'img', 'aria-label': label } as const)
  : ({ 'aria-hidden': 'true' } as const);
---

<svg
  class:list={['icon', className]}
  viewBox="0 0 24 24"
  width={size}
  height={size}
  fill="none"
  stroke="currentColor"
  stroke-width="1.75"
  stroke-linecap="round"
  stroke-linejoin="round"
  focusable="false"
  {...ariaProps}
>
  <path d={d}></path>
</svg>

<style>
  .icon {
    flex: 0 0 auto;
    color: currentColor;
  }
</style>

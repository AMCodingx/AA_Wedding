{
	"extends": "astro/tsconfigs/strict",
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"~/*": [
				"src/*"
			]
		},
		"types": [
			"astro/client"
		],
		"verbatimModuleSyntax": true,
		"resolveJsonModule": true,
		"allowImportingTsExtensions": false
	},
	"include": [
		"src",
		"astro.config.mjs",
		".astro/types.d.ts",
		"./worker-configuration.d.ts"
	],
	"exclude": [
		"dist",
		"node_modules"
	]
}